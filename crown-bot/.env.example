# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Required: Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Required: Application ID from Discord Developer Portal
DISCORD_CLIENT_ID=your_client_id_here

# Optional: Bot owner user IDs (comma-separated) for /admin sync command
OWNER_IDS=your_discord_user_id

# ─── Database ─────────────────────────────────────────────────────────────────
# Required for: tickets, reaction roles, suggestions, scheduled messages, config
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Free cluster: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/crownbot

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for the Express health-check endpoint
# Railway sets PORT automatically — do not hardcode this
PORT=8080

# ─── Sessions ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_random_secret_string

# ─── Optional Features ────────────────────────────────────────────────────────
# Channel ID for the English-only auto-reminder (fires every 15 min)
REMINDER_CHANNEL_ID=your_channel_id_here
